/* ============================================================
   智能客服知识库 — 花笺暖色极简主题 v1.1
   乳白主底 #FEFEFE · 导航米黄 #F3EDE4 · 鼠尾草绿强调 #9AA69D
   表格选中 #F0EBE4 · 导航半透明叠加 · FeedCard 轻 hover
   ============================================================ */

/* ----- 全局基色 ----- */
QWidget {
    background-color: #FEFEFE;
    color: #000000;
    font-size: 14px;
}

QMainWindow,
#ContentStack,
QStackedWidget {
    background-color: #FEFEFE;
}

QDialog {
    background-color: #FEFEFE;
    color: #000000;
}

QScrollArea {
    background-color: transparent;
    border: none;
}

QScrollArea > QWidget > QWidget {
    background-color: transparent;
}

/* ===== 顶栏 ===== */
#TopBar {
    background-color: #FEFEFE;
    border-bottom: 1px solid #E0D9CE;
}
#PageTitle {
    font-size: 17px;
    font-weight: 600;
    color: #000000;
    background: transparent;
}
#UserBadge {
    color: #757575;
    font-size: 13px;
    background: transparent;
}
#RoleBadge {
    background-color: rgba(154, 166, 157, 0.18);
    color: #6B7F74;
    border-radius: 6px;
    padding: 4px 10px;
    font-size: 12px;
    font-weight: 600;
}

/* ===== 侧边导航 ===== */
#NavSidebar {
    background-color: #F3EDE4;
    border: none;
    border-right: 1px solid #E0D9CE;
}
#NavTree {
    background-color: #F3EDE4;
    color: #000000;
    border: none;
    outline: 0;
    padding: 8px 6px;
}
#NavTree::item {
    height: 38px;
    border: none;
    padding: 0;
    margin: 0;
    color: #000000;
    background-color: transparent;
}
#NavTree::item:hover,
#NavTree::item:selected {
    background-color: transparent;
    border: none;
}

/* ===== 按钮 ===== */
QPushButton#PrimaryButton {
    background-color: #9AA69D;
    color: #FFFFFF;
    border: none;
    border-radius: 8px;
    padding: 9px 18px;
    font-size: 14px;
    font-weight: 600;
}
QPushButton#PrimaryButton:hover { background-color: #8A9690; }
QPushButton#PrimaryButton:pressed { background-color: #7A8A82; }
QPushButton#PrimaryButton:disabled {
    background-color: #D4DAD6;
    color: #FFFFFF;
}

QPushButton#GhostButton {
    background-color: #F1EEE8;
    color: #000000;
    border: 1px solid #E0D9CE;
    border-radius: 8px;
    padding: 7px 14px;
}
QPushButton#GhostButton:hover {
    color: #6B7F74;
    border-color: #9AA69D;
    background-color: #FEFEFE;
}
QPushButton#GhostButton:pressed {
    background-color: rgba(154, 166, 157, 0.12);
}
QPushButton#GhostButton[active="true"] {
    color: #6B7F74;
    border-color: rgba(154, 166, 157, 0.55);
    font-weight: 600;
    background-color: rgba(154, 166, 157, 0.18);
}

/* ===== 图标按钮（无边框 · 主题绿图标） ===== */
QPushButton#IconButton {
    background: transparent;
    border: none;
    border-radius: 8px;
    padding: 6px;
    min-width: 32px;
    min-height: 32px;
}
QPushButton#IconButton:hover {
    background: rgba(154, 166, 157, 0.14);
}
QPushButton#IconButton:pressed {
    background: rgba(154, 166, 157, 0.24);
}
QPushButton#IconButton[active="true"] {
    background: transparent;
}

QPushButton#TextLink {
    background: transparent;
    border: none;
    color: #000000;
    padding: 0 4px;
    font-size: 14px;
    font-weight: 600;
    text-align: left;
}
QPushButton#TextLink:hover {
    color: #6B7F74;
}
QPushButton#TextLink:pressed {
    color: #9AA69D;
}
QPushButton#IconButton:disabled {
    background: transparent;
    opacity: 0.4;
}

#InteractionCount {
    color: #757575;
    font-size: 13px;
    font-weight: 500;
    background: transparent;
    padding: 0 2px 0 0;
    min-width: 12px;
}
#InteractionCount[active="true"] {
    color: #6B7F74;
    font-weight: 600;
}

/* ===== 单行输入 ===== */
QLineEdit {
    background-color: #F1EEE8;
    color: #000000;
    border: 1px solid #E0D9CE;
    border-radius: 8px;
    padding: 9px 12px;
    selection-background-color: #EEF2EE;
    selection-color: #000000;
}
QLineEdit:focus {
    border: 1px solid #9AA69D;
    background-color: #FEFEFE;
}
QLineEdit:disabled {
    background-color: #F5F0E8;
    color: #757575;
}

/* ===== 下拉框 ===== */
QComboBox {
    background-color: #F1EEE8;
    color: #000000;
    border: 1px solid #E0D9CE;
    border-radius: 8px;
    padding: 8px 32px 8px 12px;
    min-height: 22px;
    combobox-popup: 0;
}
QComboBox:hover {
    border-color: #9AA69D;
}
QComboBox:focus {
    border-color: #9AA69D;
    background-color: #FEFEFE;
}
QComboBox:disabled {
    background-color: #F5F0E8;
    color: #757575;
}
QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: center right;
    width: 28px;
    border: none;
    background: transparent;
}
QComboBox::down-arrow {
    image: url(:/icons/chevron-down.svg);
    width: 14px;
    height: 14px;
}
QComboBox QAbstractItemView,
QComboBox QListView {
    background-color: #FEFEFE;
    color: #000000;
    border: 1px solid #E8E2D8;
    border-radius: 8px;
    padding: 4px 0;
    outline: 0;
    selection-background-color: #F0EBE4;
    selection-color: #000000;
}
QComboBox QAbstractItemView::item,
QComboBox QListView::item {
    min-height: 32px;
    padding: 6px 14px;
    color: #000000;
    background-color: transparent;
    border: none;
}
QComboBox QAbstractItemView::item:hover,
QComboBox QListView::item:hover {
    background-color: #FAF8F4;
    color: #000000;
}
QComboBox QAbstractItemView::item:selected,
QComboBox QListView::item:selected {
    background-color: #F0EBE4;
    color: #000000;
    font-weight: 600;
}
#ComboPopupList {
    border: none;
    background: transparent;
    outline: 0;
}

/* ===== 多行文本 / 富文本详情 ===== */
QTextEdit,
QPlainTextEdit {
    background-color: #FEFEFE;
    color: #000000;
    border: 1px solid #F1EEE8;
    border-radius: 8px;
    padding: 10px 12px;
    selection-background-color: #EEF2EE;
    selection-color: #000000;
}
QTextEdit:focus,
QPlainTextEdit:focus {
    border-color: #9AA69D;
}

QTextBrowser,
QTextBrowser#ArticleContent {
    background-color: #FEFEFE;
    color: #000000;
    border: 1px solid #F1EEE8;
    border-radius: 10px;
    padding: 14px 16px;
    selection-background-color: #EEF2EE;
    selection-color: #000000;
}

/* ===== 选项卡 ===== */
QTabWidget::pane {
    border: 1px solid #F1EEE8;
    border-radius: 0 0 10px 10px;
    background-color: #FEFEFE;
    top: -1px;
}
QTabBar::tab {
    background-color: #F3EDE4;
    color: #757575;
    border: 1px solid #E0D9CE;
    border-bottom: none;
    padding: 10px 22px;
    margin-right: 4px;
    border-top-left-radius: 8px;
    border-top-right-radius: 8px;
}
QTabBar::tab:selected {
    background-color: #FEFEFE;
    color: #6B7F74;
    font-weight: 600;
    border-bottom: 2px solid #9AA69D;
}
QTabBar::tab:hover:!selected {
    background-color: #EBE4D8;
    color: #4A4A4A;
}

/* ===== 子页面 Tab ===== */
#SubTabBar {
    background: transparent;
}
QPushButton#SubTabButton {
    background-color: #F3EDE4;
    color: #757575;
    border: 1px solid #E0D9CE;
    border-bottom: none;
    padding: 10px 22px;
    border-top-left-radius: 8px;
    border-top-right-radius: 8px;
    min-width: 96px;
}
QPushButton#SubTabButton:hover {
    background-color: #EBE4D8;
    color: #4A4A4A;
}
QPushButton#SubTabButton:checked {
    background-color: #FEFEFE;
    color: #6B7F74;
    font-weight: 600;
    border-bottom: 2px solid #9AA69D;
}
#SubTabPane {
    background-color: #FEFEFE;
    border: 1px solid #F1EEE8;
    border-radius: 0 0 10px 10px;
}

/* ===== 列表 ===== */
QListWidget {
    background-color: #FEFEFE;
    color: #000000;
    border: 1px solid #F1EEE8;
    border-radius: 8px;
    outline: 0;
}
QListWidget::item {
    padding: 10px 12px;
    border-bottom: 1px solid #F1EEE8;
    color: #000000;
    background-color: #FEFEFE;
}
QListWidget::item:hover {
    background-color: #FAF8F4;
}
QListWidget::item:selected {
    background-color: #F0EBE4;
    color: #000000;
    font-weight: 600;
}

/* ===== 表格 ===== */
QTableWidget,
QTableView {
    background-color: #FEFEFE;
    color: #000000;
    border: 1px solid #F1EEE8;
    border-radius: 8px;
    gridline-color: #F1EEE8;
    selection-background-color: #F0EBE4;
    selection-color: #000000;
    alternate-background-color: #FAF8F4;
    outline: 0;
}
QTableWidget#DataTable {
    border: 1px solid #F1EEE8;
    border-radius: 8px;
    background-color: #FEFEFE;
}
QTableWidget#DataTable::item {
    padding: 10px 12px;
}
QHeaderView::section {
    background-color: #F3EDE4;
    color: #3D3D3D;
    font-size: 13px;
    font-weight: 600;
    border: none;
    border-bottom: 1px solid #E0D9CE;
    border-right: 1px solid #F1EEE8;
    padding: 10px 12px;
    min-height: 40px;
}
QTableWidget::item,
QTableView::item {
    padding: 8px;
    color: #000000;
    background-color: #FEFEFE;
}
QTableWidget::item:alternate,
QTableView::item:alternate {
    background-color: #FAF8F4;
}
QTableWidget::item:selected,
QTableView::item:selected {
    background-color: #F0EBE4;
    color: #000000;
    font-weight: 600;
}

/* ===== 复选框 ===== */
QCheckBox {
    color: #000000;
    spacing: 8px;
    background: transparent;
}
QCheckBox::indicator {
    width: 18px;
    height: 18px;
    border: 1.5px solid #E0D9CE;
    border-radius: 4px;
    background-color: #F1EEE8;
}
QCheckBox::indicator:hover {
    border-color: #9AA69D;
    background-color: #FEFEFE;
}
QCheckBox::indicator:checked {
    background-color: #9AA69D;
    border-color: #9AA69D;
    image: url(:/icons/check-white.svg);
}
QCheckBox::indicator:checked:hover {
    background-color: #8A9690;
    border-color: #8A9690;
}
QCheckBox::indicator:disabled {
    background-color: #F5F0E8;
    border-color: #E0D9CE;
}
QCheckBox::indicator:checked:disabled {
    background-color: #D4DAD6;
    border-color: #D4DAD6;
}
QCheckBox:disabled {
    color: #757575;
}

/* ===== 登录页 ===== */
#LoginDialog {
    background-color: #FEFEFE;
}
#LoginCard {
    background-color: #FEFEFE;
    border: 1px solid #F1EEE8;
    border-radius: 14px;
}
#BrandTitle {
    font-size: 22px;
    font-weight: 700;
    color: #000000;
    background: transparent;
}
#BrandSubtitle {
    font-size: 13px;
    color: #757575;
    background: transparent;
}
#StatusLabel {
    color: #B94A48;
    font-size: 13px;
    background: transparent;
}
#HintLabel {
    color: #757575;
    font-size: 12px;
    background: transparent;
}
#PageInfoLabel {
    color: #757575;
    font-size: 13px;
    background: transparent;
    padding-left: 8px;
}
QToolButton#LinkButton {
    background: transparent;
    border: none;
    color: #757575;
    padding: 2px 0;
}
QToolButton#LinkButton:hover {
    color: #6B7F74;
}
QPushButton#LinkButton {
    background: transparent;
    border: none;
    color: #6B7F74;
    padding: 2px 0;
    text-align: left;
}
QPushButton#LinkButton:hover {
    color: #9AA69D;
}

/* ===== 占位页 ===== */
#PlaceholderCard {
    background-color: #FEFEFE;
    border: 1px solid #F1EEE8;
    border-radius: 14px;
}
#ModuleChip {
    color: #9AA69D;
    font-size: 13px;
    font-weight: 600;
    background: transparent;
}
#PlaceholderMeta {
    background-color: #F3EDE4;
    border: 1px solid #F1EEE8;
    border-radius: 10px;
    color: #4A4A4A;
    font-size: 13px;
}
#PlaceholderMeta QLabel {
    color: #4A4A4A;
    background: transparent;
}
#PendingChip {
    background-color: #F1EEE8;
    color: #757575;
    border-radius: 6px;
    padding: 5px 12px;
    font-size: 12px;
}
#PlaceholderTitle {
    font-size: 24px;
    font-weight: 700;
    color: #000000;
    background: transparent;
}
#PlaceholderHint {
    font-size: 14px;
    color: #757575;
    background: transparent;
}
#RouteChip {
    background-color: #F1EEE8;
    color: #757575;
    border-radius: 6px;
    padding: 5px 12px;
    font-size: 12px;
}
#Phase2Chip {
    background-color: #F3EDE4;
    color: #6B7F74;
    border-radius: 6px;
    padding: 5px 12px;
    font-size: 12px;
    font-weight: 600;
}

/* ===== 页面内容区 ===== */
#PageContent {
    background-color: transparent;
}

/* ===== 欢迎横幅 ===== */
#WelcomeBanner {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #F6F0E4, stop:0.45 #EAF1EC, stop:1 #F3EDE4);
    border-radius: 12px;
    border: 1px solid #F1EEE8;
}
#WelcomeTitle {
    font-size: 22px;
    font-weight: 700;
    color: #000000;
    background: transparent;
}
#WelcomeHint {
    font-size: 14px;
    color: #4A4A4A;
    background: transparent;
}

/* ===== 首页快捷入口 ===== */
#QuickEntryScroll {
    background: transparent;
    border: none;
}
#QuickEntryScroll QWidget {
    background: transparent;
}
QToolButton#QuickEntryTile {
    background-color: #FEFEFE;
    border: 1px solid #F1EEE8;
    border-radius: 10px;
    padding: 8px 6px 6px 6px;
    font-size: 12px;
    color: #4A4A4A;
}
QToolButton#QuickEntryTile:hover {
    background-color: #F6F0E4;
    border-color: #E8E2D8;
    color: #1A1A1A;
}
QToolButton#QuickEntryTile:pressed {
    background-color: #F0EBE4;
}

/* ===== 首页热门排行 ===== */
#HotRankRow {
    background-color: #F8F6F2;
    border: 1px solid transparent;
    border-radius: 8px;
}
#HotRankRow:hover {
    background-color: #F6F0E4;
    border-color: #F1EEE8;
}
#HotRankIndex {
    font-size: 13px;
    font-weight: 700;
    color: #9AA69D;
    background: transparent;
}
#HotRankTitle {
    font-size: 13px;
    color: #1A1A1A;
    background: transparent;
}
#HotRankViews {
    font-size: 12px;
    color: #757575;
    min-width: 36px;
    background: transparent;
}
#HotRankScroll {
    background: transparent;
    border: none;
}
#HotRankScroll QWidget {
    background: transparent;
}
QScrollArea#HotRankScroll QScrollBar:vertical,
QScrollArea#HotRankScroll QScrollBar:horizontal {
    width: 0;
    height: 0;
    background: transparent;
}

/* ===== 指标卡片 ===== */
#StatCard {
    background-color: #FEFEFE;
    border: 1px solid #F1EEE8;
    border-radius: 12px;
}
#StatCardLabel {
    font-size: 13px;
    color: #757575;
    background: transparent;
}
#StatCardValue {
    font-size: 28px;
    font-weight: 700;
    color: #000000;
    background: transparent;
}
#StatCardHint {
    font-size: 12px;
    color: #9AA69D;
    background: transparent;
}

/* ===== 分区卡片 ===== */
#SectionCard {
    background-color: #FEFEFE;
    border: 1px solid #F1EEE8;
    border-radius: 12px;
}
#SectionCard QLabel {
    background: transparent;
}

/* ===== 统计图表分区 ===== */
#ChartSection {
    background-color: #FEFEFE;
    border: 1px solid #F1EEE8;
    border-radius: 12px;
}
#ChartSection QLabel {
    background: transparent;
}
#ChartView {
    background: transparent;
    border: none;
    min-width: 0;
}
#KpiTile {
    background-color: #F8F6F2;
    border: 1px solid #F1EEE8;
    border-radius: 10px;
}
#KpiTileLabel {
    font-size: 12px;
    color: #757575;
    background: transparent;
}
#KpiTileValue {
    font-size: 26px;
    font-weight: 700;
    color: #1A1A1A;
    background: transparent;
}
#KpiTileValueAccent {
    font-size: 26px;
    font-weight: 700;
    color: #6B7F74;
    background: transparent;
}
#KpiTodayStrip {
    font-size: 13px;
    line-height: 1.5;
    color: #757575;
    background: transparent;
    padding: 2px 2px 0 2px;
}

#KpiGrid {
    color: #000000;
    font-size: 14px;
    line-height: 1.5;
    background: transparent;
}

#ChartLegend {
    color: #4A4A4A;
    font-size: 12px;
    line-height: 1.35;
    background: transparent;
    padding: 0;
    margin: 0;
}

#ChartLegend[vertical="true"] {
    font-size: 11px;
    line-height: 1.55;
    padding-top: 2px;
}

#ChartLegend[bottom="true"] {
    font-size: 12px;
    line-height: 1.4;
    padding-top: 2px;
    padding-bottom: 0;
}

/* ===== 知识社区 · 标签筛选 ===== */
QScrollArea#TagFilterScroll {
    background: transparent;
    border: none;
}
QScrollArea#TagFilterScroll > QWidget > QWidget {
    background: transparent;
}
QScrollArea#TagFilterScroll QScrollBar:vertical {
    width: 0;
    height: 0;
}
QScrollArea#TagFilterScroll QScrollBar:horizontal {
    height: 5px;
    background: transparent;
    margin: 0 2px 1px 2px;
}
QScrollArea#TagFilterScroll QScrollBar::handle:horizontal {
    background: #D4DAD6;
    border-radius: 2px;
    min-width: 24px;
}
QScrollArea#TagFilterScroll QScrollBar::add-line:horizontal,
QScrollArea#TagFilterScroll QScrollBar::sub-line:horizontal {
    width: 0;
    height: 0;
}

QPushButton#TagFilterChip {
    background-color: #FEFEFE;
    color: #4A4A4A;
    border: 1px solid #E8E4DC;
    border-radius: 14px;
    padding: 5px 12px;
    font-size: 13px;
    min-height: 28px;
}
QPushButton#TagFilterChip:hover {
    background-color: #F3EDE4;
    border-color: #D4CFC6;
}
QPushButton#TagFilterChip:checked {
    background-color: #9AA69D;
    color: #FFFFFF;
    border: none;
    font-weight: 600;
}

QPushButton#TagPickerChip {
    background-color: #FEFEFE;
    color: #4A4A4A;
    border: none;
    border-radius: 14px;
    padding: 7px 14px;
    font-size: 13px;
    text-align: center;
}
QPushButton#TagPickerChip:hover:!checked {
    background-color: #F3EDE4;
}
QPushButton#TagPickerChip:checked {
    background-color: #9AA69D;
    color: #FFFFFF;
    font-weight: 600;
}

/* ===== 知识社区流卡片 ===== */
#FeedCard {
    background-color: #FEFEFE;
    border: 1px solid #F1EEE8;
    border-radius: 12px;
}
#FeedCard:hover {
    border-color: #E8E2D8;
    background-color: #FAF8F4;
}
#FeedCard QWidget {
    background: transparent;
}
#FeedCardTitle {
    font-size: 16px;
    font-weight: 600;
    color: #000000;
    background: transparent;
}
#FeedCardStats {
    font-size: 12px;
    color: #757575;
    background: transparent;
}
#FeedCardSkeleton {
    background-color: #FEFEFE;
    border: 1px solid #F1EEE8;
    border-radius: 12px;
}
#SkeletonLine {
    background-color: #F1EEE8;
    border-radius: 4px;
    max-width: 9999px;
}
#SkeletonLineShort {
    background-color: #F1EEE8;
    border-radius: 4px;
    max-width: 240px;
}

#SectionTitle {
    font-size: 16px;
    font-weight: 600;
    color: #000000;
    background: transparent;
}
#LoadingLabel {
    color: #757575;
    font-size: 14px;
    background: transparent;
}
#ErrorLabel {
    color: #B94A48;
    font-size: 13px;
    background: transparent;
}

#ArticleContent {
    background-color: #FEFEFE;
    color: #000000;
    border: 1px solid #F1EEE8;
    border-radius: 10px;
}

/* ===== 表单标签 ===== */
QLabel {
    background: transparent;
    color: #000000;
}

/* ===== 滚动条 ===== */
QScrollBar:vertical {
    background: transparent;
    width: 10px;
    margin: 2px;
}
QScrollBar::handle:vertical {
    background: #E0D9CE;
    border-radius: 5px;
    min-height: 30px;
}
QScrollBar::handle:vertical:hover {
    background: #9AA69D;
}
QScrollBar:horizontal {
    background: transparent;
    height: 10px;
    margin: 2px;
}
QScrollBar::handle:horizontal {
    background: #E0D9CE;
    border-radius: 5px;
    min-width: 30px;
}
QScrollBar::handle:horizontal:hover {
    background: #9AA69D;
}
QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical,
QScrollBar::add-line:horizontal,
QScrollBar::sub-line:horizontal {
    width: 0;
    height: 0;
}
QScrollBar::add-page:vertical,
QScrollBar::sub-page:vertical,
QScrollBar::add-page:horizontal,
QScrollBar::sub-page:horizontal {
    background: transparent;
}

/* ===== 问答 / 个人中心 / 标签预览 ===== */
#AnswerCard {
    background-color: #F3EDE4;
    border: 1px solid #F1EEE8;
    border-radius: 12px;
}
#CardTitle {
    font-size: 12px;
    font-weight: 600;
    color: #9AA69D;
    background: transparent;
}
#ProfileContentStack {
    background: transparent;
}
#TagColorPreview {
    border: 1px solid #E0D9CE;
    border-radius: 6px;
    min-width: 28px;
    max-width: 28px;
    min-height: 28px;
    max-height: 28px;
}

#MutedLabel {
    font-size: 13px;
    color: #757575;
    background: transparent;
}
#MutedLine {
    color: #4A4A4A;
    font-size: 13px;
    background: transparent;
}

/* ===== 评论线程 ===== */
#CommentThread {
    background: transparent;
    border: none;
    border-bottom: 1px solid #F1EEE8;
}
#CommentItem {
    background-color: transparent;
    border: none;
    border-radius: 8px;
}
#CommentItem:hover {
    background-color: #FAF8F4;
}
#CommentReply {
    background-color: transparent;
    border: none;
    border-radius: 8px;
}
#CommentReply:hover {
    background-color: #FAF8F4;
}
#CommentUserName {
    font-size: 14px;
    font-weight: 600;
    color: #000000;
    background: transparent;
}
#CommentReplyHint {
    font-size: 12px;
    color: #757575;
    background: transparent;
}
#CommentReplyTarget {
    font-size: 12px;
    color: #4A4A4A;
    background: transparent;
}
#CommentMeta {
    font-size: 12px;
    color: #757575;
    background: transparent;
}
#CommentBody {
    font-size: 14px;
    color: #000000;
    background: transparent;
    padding-left: 0;
}

/* ===== 分类树 ===== */
QTreeWidget#DataTable {
    background-color: #FEFEFE;
    border: 1px solid #F1EEE8;
    border-radius: 8px;
    outline: 0;
    selection-background-color: #F0EBE4;
    selection-color: #000000;
    alternate-background-color: #FAF8F4;
}
QTreeWidget#DataTable::item {
    min-height: 44px;
    padding: 8px 12px;
}
QTreeWidget#DataTable::item:hover {
    background-color: #FAF8F4;
}
QTreeWidget#DataTable::item:selected {
    background-color: #F0EBE4;
    color: #000000;
    font-weight: 600;
}

/* ===== 智能问答 / AI 配置 ===== */
#QaScroll, #QaCanvas {
    background: #FEFEFE;
    border: none;
}
#ChatUserBubble {
    background: #9AA69D;
    color: #FFFFFF;
    border-radius: 12px;
    padding: 10px 14px;
    font-size: 14px;
}
#ChatBotBubble {
    background: #F3EDE4;
    border: 1px solid #F1EEE8;
    border-radius: 12px;
}
#ChatBotBubble QPushButton#IconButton {
    background: transparent;
}
#ChatBotBubble QPushButton#IconButton:hover {
    background: rgba(154, 166, 157, 0.14);
}
#ChatBotBubble QPushButton#IconButton:pressed {
    background: rgba(154, 166, 157, 0.24);
}
#ModeBadge {
    background: #F1EEE8;
    color: #757575;
    border-radius: 10px;
    padding: 2px 10px;
    font-size: 12px;
}
#CitationCard {
    background: #FAF8F4;
    border: 1px solid #F1EEE8;
    border-radius: 8px;
}
#CitationCard:hover {
    border-color: #9AA69D;
}
#CitationSnippet {
    color: #757575;
    font-size: 13px;
}

/* ----- 坐席辅助（模块 10）----- */
#AgentHead {
    background: #F7F3EC;
    border: 1px solid #EDE6DB;
    border-radius: 10px;
}
#TranscriptArea {
    background: #FAF8F4;
    border: 1px solid #F1EEE8;
    border-radius: 10px;
}
#TranscriptScroll {
    border: none;
    background: transparent;
}
#CustomerBubble {
    background: #9AA69D;
    color: #FFFFFF;
    border-radius: 12px;
    padding: 8px 12px;
    font-size: 14px;
}
#AgentBubble {
    background: #FFFFFF;
    color: #333333;
    border: 1px solid #E8E2D8;
    border-radius: 12px;
    padding: 8px 12px;
    font-size: 14px;
}
#RecommendArea {
    background: #FAF8F4;
    border: 1px solid #F1EEE8;
    border-radius: 10px;
}
#RecommendCard {
    background: #FFFFFF;
    border: 1px solid #F1EEE8;
    border-radius: 8px;
}
#RecommendCard:hover {
    border-color: #9AA69D;
}

QMenu#QaKbMenu {
    background-color: #FEFEFE;
    color: #000000;
    border: 1px solid #E8E2D8;
    border-radius: 8px;
    padding: 4px 0;
}
QMenu#QaKbMenu::item {
    min-height: 32px;
    padding: 6px 18px;
    color: #000000;
    background-color: transparent;
}
QMenu#QaKbMenu::item:selected {
    background-color: #FAF8F4;
    color: #000000;
}
QMenu#QaKbMenu::item:checked {
    background-color: #F0EBE4;
    color: #000000;
    font-weight: 600;
}
QMenu#QaKbMenu::indicator {
    width: 0;
    height: 0;
}

#FormCard {
    background: #FEFEFE;
    border: 1px solid #F1EEE8;
    border-radius: 10px;
}
#HairLine {
    color: #E0D9CE;
}
QSpinBox, QDoubleSpinBox {
    background-color: #F1EEE8;
    border: 1px solid #E0D9CE;
    border-radius: 8px;
    padding: 6px 26px 6px 10px;
    color: #000000;
    min-height: 22px;
}
QSpinBox:hover, QDoubleSpinBox:hover {
    border-color: #9AA69D;
}
QSpinBox:focus, QDoubleSpinBox:focus {
    border: 1px solid #9AA69D;
    background-color: #FEFEFE;
}
QSpinBox:disabled, QDoubleSpinBox:disabled {
    background-color: #F5F0E8;
    color: #757575;
}
QSpinBox::up-button, QDoubleSpinBox::up-button,
QSpinBox::down-button, QDoubleSpinBox::down-button {
    subcontrol-origin: border;
    width: 24px;
    border: none;
    background: transparent;
}
QSpinBox::up-button, QDoubleSpinBox::up-button {
    subcontrol-position: top right;
    border-left: 1px solid #E0D9CE;
    border-bottom: 1px solid #E0D9CE;
    border-top-right-radius: 7px;
    margin-top: 1px;
    margin-right: 1px;
    margin-bottom: 0;
}
QSpinBox::down-button, QDoubleSpinBox::down-button {
    subcontrol-position: bottom right;
    border-left: 1px solid #E0D9CE;
    border-bottom-right-radius: 7px;
    margin-bottom: 1px;
    margin-right: 1px;
}
QSpinBox::up-button:hover, QDoubleSpinBox::up-button:hover,
QSpinBox::down-button:hover, QDoubleSpinBox::down-button:hover {
    background-color: #E8E2D8;
}
QSpinBox::up-button:pressed, QDoubleSpinBox::up-button:pressed,
QSpinBox::down-button:pressed, QDoubleSpinBox::down-button:pressed {
    background-color: #D8D2C8;
}
QSpinBox::up-button:disabled, QDoubleSpinBox::up-button:disabled,
QSpinBox::down-button:disabled, QDoubleSpinBox::down-button:disabled {
    background: transparent;
}
QSpinBox::up-arrow, QDoubleSpinBox::up-arrow {
    image: url(:/icons/chevron-up.svg);
    width: 12px;
    height: 12px;
}
QSpinBox::down-arrow, QDoubleSpinBox::down-arrow {
    image: url(:/icons/chevron-down.svg);
    width: 12px;
    height: 12px;
}
QSpinBox::up-arrow:disabled, QDoubleSpinBox::up-arrow:disabled,
QSpinBox::down-arrow:disabled, QDoubleSpinBox::down-arrow:disabled {
    opacity: 0.45;
}
